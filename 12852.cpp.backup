#include <iostream>

using namespace std;

struct node{
	int data;
	int len;
	node *pre;
	node *list;
	node *next;
	void append(int n){
		node *p = new node;
		p -> data = n;
		p -> list = NULL;
		p -> next = NULL;
		p -> len = this -> len;
		p -> pre = this -> pre;
		this -> list = p;
	}
	void under(int n){
		node *p = new node;
		p -> data = n;
		p -> list = NULL;
		p -> next = NULL;
		p -> len = this -> len + 1;
		p -> pre = this;
		this -> next = p;
	}
};

