n = int(input())

word = input()
cnt = 0
word_ascii = [0 for _ in range(26)]
for i in range(len(word)):
    word_ascii[ord(word[i]) - ord('A')] += 1
for i in range(n - 1):
    line = input()
    if len(line) > len(word) + 1 or len(line) < len(word) - 1: continue
    line_ascii = [0 for _ in range(26)]
    for j in range(len(line)):
        line_ascii[ord(line[j]) - ord('A')] += 1
    num = 0
    for j in range(26):
        if line_ascii[j] != word_ascii[j]: num += 1
    if len(line) == len(word):
        if 0 <= num <= 2: cnt += 1
    else:
        if num == 1: cnt += 1
print(cnt)
